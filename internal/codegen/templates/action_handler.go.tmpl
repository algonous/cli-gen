package main

import (
	"fmt"
	"os"
)

func handleAction{{ .HandlerSuffix }}(args []string) {
	parsed := parseArgs{{ .HandlerSuffix }}(args)
	envs := map[string]string{}
{{- range .EnvNames }}
	envs["{{ . }}"] = os.Getenv("{{ . }}")
{{- end }}
{{- range .RequiredEnvs }}
	if envs["{{ . }}"] == "" {
		fmt.Fprintf(os.Stderr, "error: required env {{ . }} is not set\n")
		os.Exit(1)
	}
{{- end }}

	req, err := buildRequest{{ .HandlerSuffix }}(parsed, envs)
	if err != nil {
		fmt.Fprintf(os.Stderr, "error: %v\n", err)
		os.Exit(1)
	}
{{- if .HasBody }}
	bodyBytes, err := buildBody{{ .HandlerSuffix }}(parsed)
	if err != nil {
		fmt.Fprintf(os.Stderr, "error: %v\n", err)
		os.Exit(1)
	}
	if bodyBytes != nil {
		req.Body = bytesReaderCloser(bodyBytes)
	}
{{- end }}
	if err := executeAction{{ .HandlerSuffix }}(req); err != nil {
		fmt.Fprintf(os.Stderr, "error: %v\n", err)
		os.Exit(1)
	}
}
