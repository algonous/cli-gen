package main

import (
	"errors"
	"flag"
	"fmt"
	"os"

	"{{ .ModuleName }}/internal"
{{- if .HasGenerated }}
	"{{ .ModuleName }}/generated"
{{- end }}
{{- if .HasCustom }}
	"{{ .ModuleName }}/custom"
{{- end }}
)

var registry = map[string]func([]string){
{{- range .GeneratedActions }}
	"{{ . }}": generated.{{ handlerName . }},
{{- end }}
{{- range .CustomActions }}
	"{{ . }}": custom.{{ handlerName . }},
{{- end }}
}

func main() {
	fs := flag.NewFlagSet(os.Args[0], flag.ContinueOnError)
	fs.SetOutput(os.Stderr)
	logFile := fs.String("log-file", "", "append JSONL output to file")
	fs.Usage = func() {} // printTopHelp() handles --help output
	if err := fs.Parse(os.Args[1:]); err != nil {
		if errors.Is(err, flag.ErrHelp) {
			printTopHelp()
			os.Exit(0)
		}
		os.Exit(2)
	}
	args := fs.Args()
	internal.LogFilePath = *logFile
	if len(args) < 1 {
		printTopHelp()
		os.Exit(1)
	}

	if args[0] == "skill" {
		handleSkill(args[1:])
		return
	}

	action, ok := registry[args[0]]
	if !ok {
		fmt.Fprintf(os.Stderr, "unknown subcommand: %s\n", args[0])
		printTopHelp()
		os.Exit(1)
	}
	action(args[1:])
}

func printTopHelp() {
	fmt.Println("{{ .CliName }} - {{ .CliDescription }}")
	fmt.Println("Usage:")
	fmt.Println("  {{ .CliName }} <subcommand> [flags]")
	fmt.Println("Subcommands:")
{{- range .AllActions }}
	fmt.Println("  {{ . }}")
{{- end }}
	fmt.Println("  skill")
}
