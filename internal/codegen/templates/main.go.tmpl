package main

import (
	"errors"
	"flag"
	"fmt"
	"os"
)

var logFilePath string

func main() {
	fs := flag.NewFlagSet(os.Args[0], flag.ContinueOnError)
	fs.SetOutput(os.Stderr)
	logFile := fs.String("log-file", "", "append JSONL output to file")
	if err := fs.Parse(os.Args[1:]); err != nil {
		if errors.Is(err, flag.ErrHelp) {
			printTopHelp()
			os.Exit(0)
		}
		os.Exit(2)
	}
	args := fs.Args()
	logFilePath = *logFile
	if len(args) < 1 {
		printTopHelp()
		os.Exit(1)
	}

	switch args[0] {
	case "skill":
		handleSkill(args[1:])
{{- range .Actions }}
	case "{{ . }}":
		handleAction{{ handlerName . }}(args[1:])
{{- end }}
	default:
		fmt.Fprintf(os.Stderr, "unknown subcommand: %s\n", args[0])
		printTopHelp()
		os.Exit(1)
	}
}

func printTopHelp() {
	fmt.Println("{{ .CliName }} - {{ .CliDescription }}")
	fmt.Println("Usage:")
	fmt.Println("  {{ .CliName }} <subcommand> [flags]")
	fmt.Println("Subcommands:")
{{- range .Actions }}
	fmt.Println("  {{ . }}")
{{- end }}
	fmt.Println("  skill")
}
