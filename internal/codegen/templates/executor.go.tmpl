	body, err := readAll(resp.Body)
	if err != nil {
		return err
	}
	env, err := BuildEnvelope([]int{ {{- range $i, $code := .SuccessStatuses }}{{ if $i }}, {{ end }}{{ $code }}{{- end }} }, resp, body)
