package main

import (
	"fmt"
	"net/http"
	"net/url"
	"strconv"
	"strings"
)

var (
	_ = strconv.FormatBool
	_ = strings.Join
)

func buildRequest{{ .HandlerSuffix }}(parsed {{ .HandlerSuffix }}Args, envs map[string]string) (*http.Request, error) {
	baseURL := envs["{{ .BaseURLEnv }}"]
	path := "{{ .PathLiteral }}"
{{- range .PathArgLines }}
	{{ . }}
{{- end }}
	u, err := url.Parse(baseURL + path)
	if err != nil {
		return nil, fmt.Errorf("build url: %w", err)
	}
	query := u.Query()
{{- range .QueryLines }}
	{{ . }}
{{- end }}
	u.RawQuery = query.Encode()

	req, err := http.NewRequest("{{ .Method }}", u.String(), nil)
	if err != nil {
		return nil, err
	}
{{- range .HeaderLines }}
	{{ . }}
{{- end }}
	return req, nil
}
